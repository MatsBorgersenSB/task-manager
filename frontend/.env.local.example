# =============================================================================
# Required — local development AND Vercel production
# Copy this file to `.env.local` and fill in values from:
# Supabase Dashboard → Project Settings → API
# =============================================================================

# Supabase project URL (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key (required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Emails ending with @this-domain get role "internal"; others get "external" (required)
NEXT_PUBLIC_COMPANY_EMAIL_DOMAIN=yourcompany.com

# OpenAI API key for the in-app assistant (optional — falls back to simple replies)
OPENAI_API_KEY=sk-your-openai-key

# Password reset / email confirm redirect (must match Supabase Auth → URL Configuration)
NEXT_PUBLIC_RESET_PASSWORD_REDIRECT=https://task-manager-theta-heppa-42.vercel.app/auth/callback?next=/reset-password

# =============================================================================
# Vercel: Project Settings → Environment Variables
# Add all three variables above for Production, Preview, and Development.
#
# Supabase: Authentication → URL Configuration
#   Site URL: https://your-app.vercel.app
#   Redirect URLs:
#     https://your-app.vercel.app/auth/callback
#     http://localhost:3000/auth/callback
# =============================================================================
